# Normalize text files to LF in the repository for cross-platform consistency.
* text=auto eol=lf

# Windows command scripts should keep CRLF when checked out.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.7z binary
*.exe binary
*.dll binary
*.dmg binary
*.AppImage binary
*.deb binary
